<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════
         REPORT ACTION
    ═══════════════════════════════════════════════════════════ -->
    <record id="action_report_contract" model="ir.actions.report">
        <field name="name">طباعة العقد | Print Contract</field>
        <field name="model">construction.contract</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">construction_management.report_contract_document</field>
        <field name="report_file">construction_management.report_contract</field>
        <field name="print_report_name">'عقد_' + (object.contract_code or object.name or 'contract')</field>
        <field name="binding_model_id" ref="model_construction_contract"/>
        <field name="binding_type">report</field>
    </record>

    <!-- ═══════════════════════════════════════════════════════
         QWEB TEMPLATE
    ═══════════════════════════════════════════════════════════ -->
    <template id="report_contract_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page" style="direction: rtl; font-family: Tahoma, Arial, sans-serif; font-size: 10px;">

                        <!-- TITLE ─────────────────────────────────────── -->
                        <div style="text-align: center; margin-bottom: 16px; padding-bottom: 10px; border-bottom: 3px solid #1F4E79;">
                            <h3 style="color: #1F4E79; margin: 0 0 4px 0; font-size: 16px;">
                                عقد المقاولات — Construction Contract
                            </h3>
                            <h5 style="color: #444; margin: 0; font-size: 12px;">
                                <span t-field="doc.contract_code"/>
                                &amp;nbsp;|&amp;nbsp;
                                <t t-if="doc.contract_type == 'main'">عقد رئيسي</t>
                                <t t-elif="doc.contract_type == 'amendment'">ملحق عقد</t>
                                <t t-elif="doc.contract_type == 'addendum'">إضافة عقد</t>
                                &amp;nbsp;|&amp;nbsp;
                                <t t-if="doc.state == 'draft'"><span style="color:#888;">مسودة</span></t>
                                <t t-elif="doc.state == 'active'"><span style="color:#27ae60;">نشط</span></t>
                                <t t-elif="doc.state == 'completed'"><span style="color:#2980b9;">مكتمل</span></t>
                                <t t-elif="doc.state in ('cancelled', 'terminated')"><span style="color:#c0392b;">ملغي/مفسوخ</span></t>
                            </h5>
                        </div>

                        <!-- CONTRACT DETAILS ─────────────────────────── -->
                        <h5 style="color: #1F4E79; margin: 0 0 6px 0; padding-right: 6px; border-right: 4px solid #1F4E79; font-size: 11px;">
                            بيانات العقد
                        </h5>
                        <table style="width: 100%; border-collapse: collapse; margin-bottom: 14px; font-size: 10px;">
                            <tr>
                                <td style="width: 50%; vertical-align: top; padding-left: 8px;">
                                    <table style="width: 100%; border-collapse: collapse;">
                                        <tr>
                                            <td style="font-weight: bold; background: #eef3fb; padding: 4px 8px; border: 1px solid #ccc; width: 38%;">اسم العقد</td>
                                            <td style="padding: 4px 8px; border: 1px solid #ccc;"><span t-field="doc.name"/></td>
                                        </tr>
                                        <tr>
                                            <td style="font-weight: bold; background: #eef3fb; padding: 4px 8px; border: 1px solid #ccc;">المشروع</td>
                                            <td style="padding: 4px 8px; border: 1px solid #ccc;"><span t-field="doc.project_id"/></td>
                                        </tr>
                                        <tr>
                                            <td style="font-weight: bold; background: #eef3fb; padding: 4px 8px; border: 1px solid #ccc;">المقاول</td>
                                            <td style="padding: 4px 8px; border: 1px solid #ccc;">
                                                <t t-esc="doc.partner_id.name if doc.partner_id else '—'"/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td style="font-weight: bold; background: #eef3fb; padding: 4px 8px; border: 1px solid #ccc;">المهندس المسؤول</td>
                                            <td style="padding: 4px 8px; border: 1px solid #ccc;">
                                                <t t-esc="doc.engineer_id.name if doc.engineer_id else '—'"/>
                                            </td>
                                        </tr>
                                    </table>
                                </td>
                                <td style="width: 50%; vertical-align: top; padding-right: 8px;">
                                    <table style="width: 100%; border-collapse: collapse;">
                                        <tr>
                                            <td style="font-weight: bold; background: #eef3fb; padding: 4px 8px; border: 1px solid #ccc; width: 42%;">تاريخ التوقيع</td>
                                            <td style="padding: 4px 8px; border: 1px solid #ccc;"><span t-field="doc.date_signed"/></td>
                                        </tr>
                                        <tr>
                                            <td style="font-weight: bold; background: #eef3fb; padding: 4px 8px; border: 1px solid #ccc;">تاريخ البداية</td>
                                            <td style="padding: 4px 8px; border: 1px solid #ccc;"><span t-field="doc.date_start"/></td>
                                        </tr>
                                        <tr>
                                            <td style="font-weight: bold; background: #eef3fb; padding: 4px 8px; border: 1px solid #ccc;">الانتهاء المتوقع</td>
                                            <td style="padding: 4px 8px; border: 1px solid #ccc;"><span t-field="doc.date_end"/></td>
                                        </tr>
                                        <tr>
                                            <td style="font-weight: bold; background: #eef3fb; padding: 4px 8px; border: 1px solid #ccc;">الانتهاء الفعلي</td>
                                            <td style="padding: 4px 8px; border: 1px solid #ccc;"><span t-field="doc.date_actual_end"/></td>
                                        </tr>
                                    </table>
                                </td>
                            </tr>
                        </table>

                        <!-- FINANCIAL SUMMARY ─────────────────────────── -->
                        <h5 style="color: #1F4E79; margin: 0 0 6px 0; padding-right: 6px; border-right: 4px solid #1F4E79; font-size: 11px;">
                            الملخص المالي
                        </h5>
                        <table style="width: 100%; border-collapse: collapse; margin-bottom: 14px; font-size: 10px;">
                            <tr>
                                <!-- Financial details -->
                                <td style="width: 50%; vertical-align: top; padding-left: 8px;">
                                    <table style="width: 100%; border-collapse: collapse;">
                                        <tr>
                                            <td style="font-weight: bold; background: #eef3fb; padding: 4px 8px; border: 1px solid #ccc; width: 55%;">قيمة العقد</td>
                                            <td style="padding: 4px 8px; border: 1px solid #ccc; text-align: left; font-weight: bold; color: #1F4E79; font-family: monospace;">
                                                <t t-esc="'{:,.2f}'.format(doc.contract_value)"/>
                                                <small> <t t-esc="doc.currency_id.name or ''"/></small>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td style="font-weight: bold; background: #eef3fb; padding: 4px 8px; border: 1px solid #ccc;">نسبة الضمان</td>
                                            <td style="padding: 4px 8px; border: 1px solid #ccc; text-align: left;">
                                                <t t-esc="'%.1f' % doc.retention_percent"/>%
                                                &amp;nbsp;(<t t-esc="'{:,.2f}'.format(doc.retention_amount)"/>)
                                            </td>
                                        </tr>
                                        <tr t-if="doc.advance_percent">
                                            <td style="font-weight: bold; background: #eef3fb; padding: 4px 8px; border: 1px solid #ccc;">الدفعة المقدمة</td>
                                            <td style="padding: 4px 8px; border: 1px solid #ccc; text-align: left;">
                                                <t t-esc="'%.1f' % doc.advance_percent"/>%
                                                &amp;nbsp;(<t t-esc="'{:,.2f}'.format(doc.advance_amount)"/>)
                                            </td>
                                        </tr>
                                    </table>
                                </td>
                                <!-- Payment tracking -->
                                <td style="width: 50%; vertical-align: top; padding-right: 8px;">
                                    <table style="width: 100%; border-collapse: collapse;">
                                        <tr>
                                            <td style="font-weight: bold; background: #eef3fb; padding: 4px 8px; border: 1px solid #ccc; width: 55%;">إجمالي المجدول</td>
                                            <td style="padding: 4px 8px; border: 1px solid #ccc; text-align: left; font-family: monospace;">
                                                <t t-esc="'{:,.2f}'.format(doc.total_scheduled)"/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td style="font-weight: bold; background: #eef3fb; padding: 4px 8px; border: 1px solid #ccc;">إجمالي المدفوع</td>
                                            <td style="padding: 4px 8px; border: 1px solid #ccc; text-align: left; color: #27ae60; font-family: monospace;">
                                                <t t-esc="'{:,.2f}'.format(doc.total_paid)"/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td style="font-weight: bold; background: #eef3fb; padding: 4px 8px; border: 1px solid #ccc;">الرصيد المستحق</td>
                                            <td style="padding: 4px 8px; border: 1px solid #ccc; text-align: left; color: #e67e22; font-family: monospace;">
                                                <t t-esc="'{:,.2f}'.format(doc.balance_due)"/>
                                            </td>
                                        </tr>
                                    </table>
                                </td>
                            </tr>
                        </table>

                        <!-- PAYMENT SCHEDULE ─────────────────────────── -->
                        <t t-if="doc.payment_line_ids">
                            <h5 style="color: #1F4E79; margin: 0 0 6px 0; padding-right: 6px; border-right: 4px solid #1F4E79; font-size: 11px;">
                                جدول الدفعات
                            </h5>
                            <table style="width: 100%; border-collapse: collapse; font-size: 9px; margin-bottom: 14px;">
                                <thead>
                                    <tr style="background-color: #1F4E79; color: white; text-align: center;">
                                        <th style="padding: 5px 3px; border: 1px solid #ccc; width: 4%;">#</th>
                                        <th style="padding: 5px 3px; border: 1px solid #ccc; width: 28%;">وصف الدفعة</th>
                                        <th style="padding: 5px 3px; border: 1px solid #ccc; width: 14%;">النوع</th>
                                        <th style="padding: 5px 3px; border: 1px solid #ccc; width: 13%;">تاريخ الاستحقاق</th>
                                        <th style="padding: 5px 3px; border: 1px solid #ccc; width: 8%;">النسبة %</th>
                                        <th style="padding: 5px 3px; border: 1px solid #ccc; width: 15%;">المبلغ</th>
                                        <th style="padding: 5px 3px; border: 1px solid #ccc; width: 10%;">الحالة</th>
                                        <th style="padding: 5px 3px; border: 1px solid #ccc; width: 13%;">تاريخ الدفع</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="doc.payment_line_ids" t-as="pline">
                                        <tr t-att-style="'background-color:' + ('#e8f4e8' if pline.state == 'paid' else ('#fff8e1' if pline.state == 'due' else ('#f7f9fc' if pline_odd else '#ffffff'))) + ';'">
                                            <td style="padding: 3px 4px; border: 1px solid #ddd; text-align: center;"><t t-esc="pline_index + 1"/></td>
                                            <td style="padding: 3px 4px; border: 1px solid #ddd; text-align: right;"><span t-field="pline.name"/></td>
                                            <td style="padding: 3px 4px; border: 1px solid #ddd; text-align: center; font-size: 8px;">
                                                <t t-if="pline.payment_type == 'advance'">دفعة مقدمة</t>
                                                <t t-elif="pline.payment_type == 'milestone'">مرحلة</t>
                                                <t t-elif="pline.payment_type == 'retention'">إفراج ضمان</t>
                                                <t t-elif="pline.payment_type == 'final'">دفعة نهائية</t>
                                            </td>
                                            <td style="padding: 3px 4px; border: 1px solid #ddd; text-align: center;"><span t-field="pline.due_date"/></td>
                                            <td style="padding: 3px 4px; border: 1px solid #ddd; text-align: center;"><t t-esc="'%.1f' % pline.percent if pline.percent else '—'"/>%</td>
                                            <td style="padding: 3px 4px; border: 1px solid #ddd; text-align: left; font-weight: bold; font-family: monospace;"><t t-esc="'{:,.2f}'.format(pline.amount)"/></td>
                                            <td style="padding: 3px 4px; border: 1px solid #ddd; text-align: center; font-size: 8px;">
                                                <t t-if="pline.state == 'paid'"><span style="color:#27ae60; font-weight:bold;">مدفوع ✓</span></t>
                                                <t t-elif="pline.state == 'due'"><span style="color:#e67e22;">مستحق</span></t>
                                                <t t-else=""><span style="color:#888;">معلق</span></t>
                                            </td>
                                            <td style="padding: 3px 4px; border: 1px solid #ddd; text-align: center;"><span t-field="pline.paid_date"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                                <tfoot>
                                    <tr style="background-color: #1F4E79; color: white; font-weight: bold; font-size: 10px;">
                                        <td colspan="5" style="padding: 5px 8px; border: 1px solid #ccc; text-align: right;">الإجمالي</td>
                                        <td style="padding: 5px 8px; border: 1px solid #ccc; text-align: left; font-family: monospace;">
                                            <t t-esc="'{:,.2f}'.format(doc.total_scheduled)"/>
                                            <small> <t t-esc="doc.currency_id.name or ''"/></small>
                                        </td>
                                        <td colspan="2" style="padding: 5px 8px; border: 1px solid #ccc;"></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </t>

                        <!-- SUBCONTRACTS SUMMARY ─────────────────────── -->
                        <t t-if="doc.subcontract_ids">
                            <h5 style="color: #1F4E79; margin: 0 0 6px 0; padding-right: 6px; border-right: 4px solid #1F4E79; font-size: 11px;">
                                عقود الباطن (<t t-esc="len(doc.subcontract_ids)"/> عقود)
                            </h5>
                            <table style="width: 100%; border-collapse: collapse; font-size: 9px; margin-bottom: 14px;">
                                <thead>
                                    <tr style="background-color: #1F4E79; color: white; text-align: center;">
                                        <th style="padding: 4px 3px; border: 1px solid #ccc; width: 5%;">#</th>
                                        <th style="padding: 4px 3px; border: 1px solid #ccc;">عقد الباطن</th>
                                        <th style="padding: 4px 3px; border: 1px solid #ccc;">مقاول الباطن</th>
                                        <th style="padding: 4px 3px; border: 1px solid #ccc; width: 12%;">تاريخ البداية</th>
                                        <th style="padding: 4px 3px; border: 1px solid #ccc; width: 12%;">تاريخ الانتهاء</th>
                                        <th style="padding: 4px 3px; border: 1px solid #ccc; width: 15%;">القيمة</th>
                                        <th style="padding: 4px 3px; border: 1px solid #ccc; width: 10%;">الحالة</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="doc.subcontract_ids" t-as="sub">
                                        <tr t-att-style="'background-color:' + ('#f7f9fc' if sub_odd else '#ffffff') + ';'">
                                            <td style="padding: 3px; border: 1px solid #ddd; text-align: center;"><t t-esc="sub_index + 1"/></td>
                                            <td style="padding: 3px; border: 1px solid #ddd; text-align: right;"><span t-field="sub.name"/></td>
                                            <td style="padding: 3px; border: 1px solid #ddd; text-align: right;"><t t-esc="sub.partner_id.name if sub.partner_id else '—'"/></td>
                                            <td style="padding: 3px; border: 1px solid #ddd; text-align: center;"><span t-field="sub.date_start"/></td>
                                            <td style="padding: 3px; border: 1px solid #ddd; text-align: center;"><span t-field="sub.date_end"/></td>
                                            <td style="padding: 3px; border: 1px solid #ddd; text-align: left; font-family: monospace;"><t t-esc="'{:,.2f}'.format(sub.subcontract_value)"/></td>
                                            <td style="padding: 3px; border: 1px solid #ddd; text-align: center; font-size: 8px;">
                                                <t t-if="sub.state == 'draft'">مسودة</t>
                                                <t t-elif="sub.state == 'active'">نشط</t>
                                                <t t-elif="sub.state == 'completed'">مكتمل</t>
                                                <t t-elif="sub.state == 'cancelled'">ملغي</t>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>

                        <!-- SIGNATURE BLOCKS ──────────────────────────── -->
                        <table style="width: 100%; border-collapse: collapse; margin-top: 40px; page-break-inside: avoid;">
                            <tr>
                                <td style="width: 33%; text-align: center; padding: 8px 15px; vertical-align: bottom;">
                                    <div style="border-top: 1px solid #333; padding-top: 6px; margin-top: 55px;">
                                        <strong style="font-size: 11px;">المقاول / المقاولة</strong><br/>
                                        <small style="color: #666; font-size: 9px;">
                                            <t t-esc="doc.partner_id.name if doc.partner_id else '..............................'"/>
                                        </small>
                                    </div>
                                </td>
                                <td style="width: 34%; text-align: center; padding: 8px 15px; vertical-align: bottom; border-right: 1px dashed #ccc; border-left: 1px dashed #ccc;">
                                    <div style="border-top: 1px solid #333; padding-top: 6px; margin-top: 55px;">
                                        <strong style="font-size: 11px;">المهندس المسؤول</strong><br/>
                                        <small style="color: #666; font-size: 9px;">
                                            <t t-esc="doc.engineer_id.name if doc.engineer_id else '..............................'"/>
                                        </small>
                                    </div>
                                </td>
                                <td style="width: 33%; text-align: center; padding: 8px 15px; vertical-align: bottom;">
                                    <div style="border-top: 1px solid #333; padding-top: 6px; margin-top: 55px;">
                                        <strong style="font-size: 11px;">صاحب العمل / المالك</strong><br/>
                                        <small style="color: #666; font-size: 9px;">..............................</small>
                                    </div>
                                </td>
                            </tr>
                        </table>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
