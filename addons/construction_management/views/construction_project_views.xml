<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════
         FORM VIEW
    ═══════════════════════════════════════════ -->
    <record id="view_construction_project_form" model="ir.ui.view">
        <field name="name">construction.project.form</field>
        <field name="model">construction.project</field>
        <field name="arch" type="xml">
            <form string="مشروع المقاولات">

                <header>
                    <button name="action_activate" string="تفعيل"
                            type="object" class="oe_highlight"
                            invisible="state != 'draft'"/>
                    <button name="action_pause" string="إيقاف مؤقت"
                            type="object"
                            invisible="state != 'active'"/>
                    <button name="action_activate" string="استئناف"
                            type="object" class="oe_highlight"
                            invisible="state != 'paused'"/>
                    <button name="action_done" string="إغلاق المشروع"
                            type="object" class="oe_highlight"
                            invisible="state not in ('active', 'paused')"/>
                    <button name="action_cancel" string="إلغاء"
                            type="object"
                            invisible="state in ('done', 'cancelled')"/>
                    <button name="action_reset_draft" string="إعادة للمسودة"
                            type="object"
                            invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,active,done"/>
                </header>

                <sheet>
                    <!-- Smart buttons (populated in later phases) -->
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" icon="fa-list-alt"
                                invisible="boq_count == 0" type="object" name="action_view_boq">
                            <field name="boq_count" widget="statinfo" string="BOQ"/>
                        </button>
                        <button class="oe_stat_button" icon="fa-file-text-o"
                                invisible="contract_count == 0" type="object" name="action_view_contracts">
                            <field name="contract_count" widget="statinfo" string="عقود"/>
                        </button>
                        <button class="oe_stat_button" icon="fa-certificate"
                                invisible="certificate_count == 0" type="object" name="action_view_certificates">
                            <field name="certificate_count" widget="statinfo" string="شهادات"/>
                        </button>
                    </div>

                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="اسم المشروع"/>
                        </h1>
                        <div>
                            <field name="project_code" class="oe_inline text-muted"/>
                            <span class="mx-2 text-muted">|</span>
                            <field name="project_type" class="oe_inline"/>
                        </div>
                    </div>

                    <group>
                        <group string="أطراف المشروع">
                            <field name="partner_id" widget="many2one_avatar"/>
                            <field name="engineer_id" widget="many2one_avatar_user"/>
                        </group>
                        <group string="الجدول الزمني">
                            <field name="date_start"/>
                            <field name="date_end"/>
                        </group>
                    </group>

                    <notebook>

                        <!-- Tab 1: Location -->
                        <page string="الموقع | Location" name="location">
                            <group>
                                <group string="الموقع الجغرافي">
                                    <field name="region_id"/>
                                    <field name="city_id"/>
                                    <field name="location"
                                           placeholder="وصف إضافي للموقع"/>
                                </group>
                                <group string="التراخيص | Permits">
                                    <field name="building_permit"/>
                                    <field name="municipality_ref"/>
                                    <field name="permit_expiry"/>
                                    <field name="permit_status"
                                           widget="badge"
                                           decoration-success="permit_status == 'valid'"
                                           decoration-warning="permit_status == 'expiring'"
                                           decoration-danger="permit_status == 'expired'"
                                           invisible="not permit_expiry"/>
                                </group>
                            </group>
                            <group string="العنوان الوطني للموقع | Site National Address">
                                <group>
                                    <field name="site_building_no"
                                           placeholder="4 أرقام — مثال: 3542"/>
                                    <field name="site_street"
                                           placeholder="اسم الشارع"/>
                                    <field name="site_secondary_no"
                                           placeholder="4 أرقام — مثال: 7894"/>
                                    <field name="site_district"
                                           placeholder="اسم الحي"/>
                                </group>
                                <group>
                                    <field name="site_postal_code"
                                           placeholder="5 أرقام — مثال: 12212"/>
                                    <field name="site_national_address" readonly="1"/>
                                </group>
                            </group>
                        </page>

                        <!-- Tab 2: Financials -->
                        <page string="الميزانية | Financials" name="financials">
                            <group>
                                <group string="قيم العقد">
                                    <field name="currency_id"/>
                                    <field name="contract_value"/>
                                    <field name="budget_estimated"/>
                                </group>
                                <group string="التتبع المالي">
                                    <field name="cost_actual" readonly="1"/>
                                    <field name="progress_percent"
                                           readonly="1"
                                           widget="progressbar"/>
                                </group>
                            </group>
                        </page>

                        <!-- Tab 3: Description -->
                        <page string="الوصف | Description" name="description">
                            <field name="description"/>
                        </page>

                    </notebook>
                </sheet>

                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>

            </form>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════
         LIST VIEW
    ═══════════════════════════════════════════ -->
    <record id="view_construction_project_list" model="ir.ui.view">
        <field name="name">construction.project.list</field>
        <field name="model">construction.project</field>
        <field name="arch" type="xml">
            <tree string="المشاريع"
                  decoration-success="state == 'done'"
                  decoration-info="state == 'active'"
                  decoration-warning="state == 'paused'"
                  decoration-muted="state == 'cancelled'">
                <field name="project_code" optional="show"/>
                <field name="name"/>
                <field name="project_type" optional="show"/>
                <field name="partner_id"/>
                <field name="engineer_id" optional="show"/>
                <field name="region_id" optional="show"/>
                <field name="city_id" optional="show"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="contract_value" optional="show" sum="إجمالي العقود"/>
                <field name="progress_percent" widget="progressbar" optional="show"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'done'"
                       decoration-info="state == 'active'"
                       decoration-warning="state == 'paused'"
                       decoration-danger="state == 'cancelled'"/>
            </tree>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════
         KANBAN VIEW
    ═══════════════════════════════════════════ -->
    <record id="view_construction_project_kanban" model="ir.ui.view">
        <field name="name">construction.project.kanban</field>
        <field name="model">construction.project</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="state"/>
                <field name="currency_id"/>
                <progressbar field="state"
                             colors='{"done": "success", "active": "info", "paused": "warning", "cancelled": "danger"}'/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_kanban_record_has_image_fill">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                    <small class="o_kanban_record_subtitle text-muted">
                                        <field name="project_code"/>
                                    </small>
                                </div>
                                <field name="state" widget="label_selection"
                                       options="{'classes': {
                                           'draft':     'default',
                                           'active':    'info',
                                           'paused':    'warning',
                                           'done':      'success',
                                           'cancelled': 'danger'
                                       }}"/>
                            </div>
                            <div class="o_kanban_record_body">
                                <div t-if="record.partner_id.value">
                                    <i class="fa fa-user me-1 text-muted" title="العميل"/>
                                    <field name="partner_id"/>
                                </div>
                                <div t-if="record.city_id.value">
                                    <i class="fa fa-map-marker me-1 text-muted" title="المدينة"/>
                                    <field name="city_id"/>
                                </div>
                                <div t-if="record.contract_value.value">
                                    <i class="fa fa-money me-1 text-muted" title="قيمة العقد"/>
                                    <field name="contract_value" widget="monetary"/>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <field name="date_end" widget="date"/>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <field name="engineer_id" widget="many2one_avatar_user"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════
         SEARCH VIEW
    ═══════════════════════════════════════════ -->
    <record id="view_construction_project_search" model="ir.ui.view">
        <field name="name">construction.project.search</field>
        <field name="model">construction.project</field>
        <field name="arch" type="xml">
            <search string="بحث في المشاريع">
                <field name="name" string="المشروع"/>
                <field name="project_code" string="الرقم"/>
                <field name="partner_id" string="العميل"/>
                <field name="engineer_id" string="المهندس"/>
                <field name="region_id" string="المنطقة"/>
                <field name="city_id" string="المدينة"/>
                <separator/>
                <filter string="نشط" name="active"
                        domain="[('state', '=', 'active')]"/>
                <filter string="مسودة" name="draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter string="مكتمل" name="done"
                        domain="[('state', '=', 'done')]"/>
                <filter string="ملغي" name="cancelled"
                        domain="[('state', '=', 'cancelled')]"/>
                <separator/>
                <filter string="مشاريعي" name="my_projects"
                        domain="[('engineer_id', '=', uid)]"/>
                <separator/>
                <filter string="سكني" name="residential"
                        domain="[('project_type', '=', 'residential')]"/>
                <filter string="تجاري" name="commercial"
                        domain="[('project_type', '=', 'commercial')]"/>
                <filter string="بنية تحتية" name="infra"
                        domain="[('project_type', '=', 'infra')]"/>
                <group expand="0" string="تجميع بـ | Group By">
                    <filter string="الحالة"       name="group_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="النوع"        name="group_type"
                            context="{'group_by': 'project_type'}"/>
                    <filter string="المنطقة"      name="group_region"
                            context="{'group_by': 'region_id'}"/>
                    <filter string="المهندس"      name="group_engineer"
                            context="{'group_by': 'engineer_id'}"/>
                    <filter string="سنة البداية"  name="group_year"
                            context="{'group_by': 'date_start:year'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════
         WINDOW ACTION
    ═══════════════════════════════════════════ -->
    <record id="action_construction_project" model="ir.actions.act_window">
        <field name="name">المشاريع | Projects</field>
        <field name="res_model">construction.project</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_construction_project_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                أنشئ مشروعك الأول
            </p>
            <p>
                أضف مشاريع المقاولات وتتبع الإنجاز والتكاليف والعقود من مكان واحد.
            </p>
        </field>
    </record>


</odoo>
