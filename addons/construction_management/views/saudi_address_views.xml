<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Saudi Region — list & form -->
    <record id="view_saudi_region_list" model="ir.ui.view">
        <field name="name">construction.saudi.region.list</field>
        <field name="model">construction.saudi.region</field>
        <field name="arch" type="xml">
            <tree string="المناطق الإدارية">
                <field name="code"/>
                <field name="name_ar"/>
                <field name="name"/>
                <field name="city_count" string="المدن"/>
            </tree>
        </field>
    </record>

    <record id="view_saudi_region_form" model="ir.ui.view">
        <field name="name">construction.saudi.region.form</field>
        <field name="model">construction.saudi.region</field>
        <field name="arch" type="xml">
            <form string="منطقة إدارية">
                <sheet>
                    <group>
                        <group>
                            <field name="name_ar"/>
                            <field name="name"/>
                            <field name="code"/>
                        </group>
                    </group>
                    <field name="city_ids">
                        <tree editable="bottom">
                            <field name="name_ar"/>
                            <field name="name"/>
                        </tree>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_construction_saudi_region" model="ir.actions.act_window">
        <field name="name">المناطق والمدن | Regions &amp; Cities</field>
        <field name="res_model">construction.saudi.region</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
